# ==========================================
# CLINIC BRANDING & PDF EXPORT SYSTEM
# Root .gitignore
# ==========================================

# Local Database
db/data/

# Environment Variables / Sensitive Data
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# Docker logs and temporary files
*.log
.docker-compose.tmp

# Node.js (Dependencies & Package Caches)
node_modules/
backend/node_modules/
frontend/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Backend Build outputs & mounts
backend/dist/
backend/ECOGRAFIAS/

# Frontend Build & Next.js cache
frontend/.next/
frontend/out/
frontend/build/
frontend/tsconfig.tsbuildinfo
frontend/next-env.d.ts

# Vercel deployments
frontend/.vercel/
.vercel

# Python (from extract_assets.py and other scripts)
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
.pytest_cache/

# OS-specific garbage files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs & Editor configurations
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Agent Logs and cache
.agents/
.agent/

# Microsoft Office Temp Files (e.g. from Word template editing)
~$*.docx
~$*.doc
~$*.xlsx
~$*.xls
