# ==========================================
# CONFIGURACIÓN DE SEGURIDAD — CLÍNICA RAG
# ==========================================
# ⚠️  IMPORTANTE: No copie este archivo directamente.
# Cree su propio .env y reemplace TODOS los valores.
# El servidor NO arrancará sin estas variables configuradas.

# ==========================================
# Base de datos PostgreSQL
# ==========================================
DATABASE_URL=postgresql://postgres:SU_CONTRASEÑA_SEGURA_AQUI@localhost:5432/clinica_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=SU_CONTRASEÑA_SEGURA_AQUI
POSTGRES_DB=clinica_rag

# ==========================================
# Seguridad y Autenticación
# ==========================================
# JWT Secret: Genere un string aleatorio de al menos 32 caracteres.
# Puede usar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=GENERE_UN_STRING_ALEATORIO_DE_32_CARACTERES_MINIMO

# Credenciales del Administrador
# ⚠️ Use una contraseña fuerte de al menos 8 caracteres
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CAMBIE_ESTA_CONTRASEÑA_FUERTE

# Token del Administrador: Genere un string aleatorio de al menos 32 caracteres.
# Puede usar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=GENERE_UN_TOKEN_ALEATORIO_DE_32_CARACTERES_MINIMO

# ==========================================
# URL del API (para el frontend en red local)
# ==========================================
NEXT_PUBLIC_API_URL=http://localhost:5000
PORT=5000

# ==========================================
# LM Studio (modelo Gemma local)
# ==========================================
LM_STUDIO_API_URL=http://host.docker.internal:1234/v1

# ==========================================
# Groq Whisper API Key — obtener en https://console.groq.com
# ==========================================
GROQ_API_KEY=su_groq_api_key_aqui

# ==========================================
# Gemini API Keys — obtener en https://aistudio.google.com/apikey
# ==========================================
GEMINI_API_KEY=su_gemini_api_key_aqui
# Opcional: Lista de múltiples claves de Gemini para rotación y tolerancia a fallos por cuota
# GEMINI_API_KEYS=key1,key2,key3

# ==========================================
# Contraseña por defecto para médicos migrados (opcional)
# ==========================================
# Solo se usa para asignar contraseña inicial a médicos preexistentes sin credenciales.
# Los médicos deben cambiar esta contraseña después del primer login.
# DEFAULT_DOCTOR_PASSWORD=CambiarMe2026!
